#include <bits/stdc++.h>
using namespace std;


int main(void){
  ios::sync_with_stdio(0);
  cin.tie(0);
  int a,b,c,m=0;
  cin>>a>>b>>c;
  if(a==b&&b==c){
    m=10000+1000*a;
  }
  else if(a==b||a==c){
    m=1000+100*a;
  }
  else if(b==c){
    m=1000+100*b;
  }
  else{
    m=max({a,b,c})*100;
  }
  cout<<m;
}
