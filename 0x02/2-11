#include <bits/stdc++.h>
using namespace std;
int main(void){
  ios::sync_with_stdio(0);
  cin.tie(0);
  int n,odd=0,min=100;
  for(int i=0;i<7;i++){
    cin>>n;
    if(n%2!=0){
      odd+=n;
      if(n<min){
        min=n;
      }
    }
  }
  if(odd==0){
    cout<<"-1";
  }
  else{
    cout<<odd<<'\n'<<min;
  }
 
}
