#include <bits/stdc++.h>
using namespace std;
int main(void){
  ios::sync_with_stdio(0);
  cin.tie(0);
  int a[4];
  int count=0;
  for(int i=0;i<3;i++){
    for(int j=0;j<4;j++){
        cin>>a[j];
        if(a[j]==1){
          count++;
        }
    }
    if(count==4){
      cout<<"E"<<'\n';
    }
    if(count==3){
      cout<<"A"<<'\n';
    }
    if(count==2){
      cout<<"B"<<'\n';
    }
    if(count==1){
      cout<<"C"<<'\n';
    }
    if(count==0){
      cout<<"D"<<'\n';
    }
    count=0;
  }
}//문자열로 영어 생성후 1의 개수 번째의 문자 출력하면 더 수월
